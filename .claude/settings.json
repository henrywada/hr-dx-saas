{
  "enabledPlugins": {
    "product-management@knowledge-work-plugins": true,
    "engineering@knowledge-work-plugins": true,
    "design@knowledge-work-plugins": true,
    "human-resources@knowledge-work-plugins": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"let d='';process.stdin.on('data',c=>d+=c).on('end',()=>{try{const f=JSON.parse(d).tool_input?.file_path;const p=process.env.CLAUDE_PROJECT_DIR;if(f&&p&&f.startsWith(p+'/')){require('child_process').execSync('npx prettier --write --ignore-unknown '+JSON.stringify(f),{stdio:'inherit'})}}catch(e){console.error('[format-hook] '+e.message)}})\"",
            "description": "編集されたファイルのみをプロジェクトの Prettier で整形（stdin の JSON から対象パスを取得。プロジェクト外のファイルは対象外）"
          }
        ]
      }
    ]
  }
}
