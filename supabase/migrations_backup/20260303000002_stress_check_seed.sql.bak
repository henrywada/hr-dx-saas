-- ============================================================
-- Phase 2: ストレスチェック 57問 質問マスタ シードデータ
-- 職業性ストレス簡易調査票（57項目）準拠
-- ============================================================
-- 実行前提: 20260303000000_stress_check.sql が適用済みであること
-- ============================================================

-- ============================================================
-- 1. 質問マスタ INSERT（57問）
-- ============================================================
-- カラム説明:
--   category: A=仕事のストレス要因, B=心身のストレス反応, C=周囲のサポート, D=満足度
--   question_number: カテゴリ内の問番号（A1〜A17, B1〜B29, C1〜C9, D1〜D2）
--   sort_order: 全体通し番号（1〜57）
--   question_text: 質問文
--   response_scale: 回答尺度タイプ
--   is_reverse_scored: 逆転項目フラグ（trueの場合、得点を反転して計算）
--   scale_name: 素点換算表の尺度名
--   scale_group: 尺度グループ（高ストレス判定用）
--     'stressor'  = ストレスの原因と考えられる因子（A領域9尺度）
--     'reaction'  = ストレスによっておこる心身の反応（B領域6尺度）
--     'support'   = ストレス反応に影響を与える他の因子（C領域3尺度）
--     'satisfaction' = 仕事や生活の満足度（D領域1尺度）※高ストレス判定には含まない
--   is_in_short_version: 簡略版23問に含まれるか
-- ============================================================

INSERT INTO public.stress_check_questions (
  category, question_number, sort_order, question_text,
  response_scale, is_reverse_scored,
  scale_name, scale_group, is_in_short_version
) VALUES

-- ============================================================
-- A: あなたの仕事についてうかがいます
-- 回答尺度: そうだ(4) / まあそうだ(3) / ややちがう(2) / ちがう(1)
-- ※逆転項目は「そうだ」がストレス低い方向の質問
-- ============================================================

-- 心理的な仕事の負担（量）: 素点 = 15-(A1+A2+A3)
('A', 1,  1, '非常にたくさんの仕事をしなければならない',
 'agreement', false, '心理的な仕事の負担（量）', 'stressor', true),
('A', 2,  2, '時間内に仕事が処理しきれない',
 'agreement', false, '心理的な仕事の負担（量）', 'stressor', true),
('A', 3,  3, '一生懸命働かなければならない',
 'agreement', false, '心理的な仕事の負担（量）', 'stressor', true),

-- 心理的な仕事の負担（質）: 素点 = 15-(A4+A5+A6)
('A', 4,  4, 'かなり注意を集中する必要がある',
 'agreement', false, '心理的な仕事の負担（質）', 'stressor', false),
('A', 5,  5, '高度の知識や技術が必要なむずかしい仕事だ',
 'agreement', false, '心理的な仕事の負担（質）', 'stressor', false),
('A', 6,  6, '勤務時間中はいつも仕事のことを考えていなければならない',
 'agreement', false, '心理的な仕事の負担（質）', 'stressor', false),

-- 自覚的な身体的負担度: 素点 = 5-A7
('A', 7,  7, 'からだを大変よく使う仕事だ',
