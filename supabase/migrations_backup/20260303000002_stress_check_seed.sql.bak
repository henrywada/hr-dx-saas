-- 家族・友人からのサポート: 15-(C3+C6+C9)  得点範囲 3〜12
('家族・友人からのサポート', 'support', 'male',   '15-(C3+C6+C9)',
  3, 6,   7, 8,   9, 9,  10, 11,  12, 12),
('家族・友人からのサポート', 'support', 'female', '15-(C3+C6+C9)',
  3, 6,   7, 8,   9, 9,  10, 11,  12, 12),

-- ============================================================
-- 【仕事や生活の満足度】(D領域 1尺度) ※高ストレス判定には含まない
-- ============================================================

-- 仕事や生活の満足度: 10-(D1+D2)  得点範囲 2〜8
('仕事や生活の満足度', 'satisfaction', 'male',   '10-(D1+D2)',
  2, 3,   4, 4,   5, 6,   7, 7,   8, 8),
('仕事や生活の満足度', 'satisfaction', 'female', '10-(D1+D2)',
  2, 3,   4, 4,   5, 6,   7, 7,   8, 8);


-- ============================================================
-- 3. 高ストレス判定基準マスタ
-- ============================================================
-- 評価基準の例（その1）: 素点合計方式
-- 評価基準の例（その2）: 5段階換算方式
-- ============================================================

CREATE TABLE IF NOT EXISTS public.stress_check_high_stress_criteria (
  id uuid DEFAULT gen_random_uuid() PRIMARY KEY,
  method text NOT NULL CHECK (method IN ('raw_score', 'converted_score')),
  questionnaire_type text NOT NULL CHECK (questionnaire_type IN ('57', '23')),
  description text NOT NULL,
  -- 条件①: B領域のみで高ストレス
  condition_1_b_threshold int NOT NULL,
  -- 条件②: A+C領域の閾値 AND B領域の閾値
  condition_2_ac_threshold int NOT NULL,
  condition_2_b_threshold int NOT NULL,
  UNIQUE (method, questionnaire_type)
);

ALTER TABLE public.stress_check_high_stress_criteria ENABLE ROW LEVEL SECURITY;

CREATE POLICY "high_stress_criteria_select_all" ON public.stress_check_high_stress_criteria
  FOR SELECT USING (true);

CREATE POLICY "high_stress_criteria_insert_admin" ON public.stress_check_high_stress_criteria
  FOR INSERT WITH CHECK (
    (SELECT auth.uid()) = 'e97488f9-02be-4b0b-9dc9-ddb0c2902999'::uuid
  );

INSERT INTO public.stress_check_high_stress_criteria (
  method, questionnaire_type, description,
  condition_1_b_threshold,
  condition_2_ac_threshold, condition_2_b_threshold
) VALUES
-- 評価基準の例（その1）: 素点合計方式（57問）
-- ①B領域29項目合計 ≥ 77 → 高ストレス
-- ②A領域17項目+C領域9項目合計 ≥ 76 かつ B領域合計 ≥ 63 → 高ストレス
('raw_score', '57',
 '素点合計方式（マニュアルP42準拠）: B≥77 or (AC≥76 and B≥63)',
 77, 76, 63),

-- 評価基準の例（その1）: 素点合計方式（23問）
-- ①B領域11項目合計 ≥ 31 → 高ストレス
-- ②A領域6項目+C領域6項目合計 ≥ 39 かつ B領域合計 ≥ 23 → 高ストレス
('raw_score', '23',
 '素点合計方式（マニュアルP42準拠）: B≥31 or (AC≥39 and B≥23)',
 31, 39, 23),

-- 評価基準の例（その2）: 5段階換算方式（57問）
-- ①B領域6尺度の5段階合計 ≤ 12（平均2.00以下）→ 高ストレス
-- ②A領域9尺度+C領域3尺度=12尺度の5段階合計 ≤ 26（平均2.17以下）
--   かつ B領域6尺度合計 ≤ 17（平均2.83以下）→ 高ストレス
-- ※converted_scoreの場合、thresholdは「以下」で判定（低い=ストレス高い）
('converted_score', '57',
 '5段階換算方式（マニュアルP43準拠）: B≤12 or (AC≤26 and B≤17)',
 12, 26, 17),

-- 評価基準の例（その2）: 5段階換算方式（23問）
-- ①B領域5尺度合計 ≤ 11（平均2.20以下）→ 高ストレス
-- ②A領域2尺度+C領域2尺度=4尺度合計 ≤ 8（平均2.00以下）
--   かつ B領域5尺度合計 ≤ 16（平均3.20以下）→ 高ストレス
('converted_score', '23',
 '5段階換算方式（マニュアルP44準拠）: B≤11 or (AC≤8 and B≤16)',
 11, 8, 16);


-- ============================================================
-- 4. 回答選択肢マスタ（フロントエンド表示用）
-- ============================================================

CREATE TABLE IF NOT EXISTS public.stress_check_response_options (
  id uuid DEFAULT gen_random_uuid() PRIMARY KEY,
  response_scale text NOT NULL,
  option_value int NOT NULL,
  option_label text NOT NULL,
  sort_order int NOT NULL,
  UNIQUE (response_scale, option_value)
);

ALTER TABLE public.stress_check_response_options ENABLE ROW LEVEL SECURITY;

CREATE POLICY "response_options_select_all" ON public.stress_check_response_options
  FOR SELECT USING (true);

INSERT INTO public.stress_check_response_options (response_scale, option_value, option_label, sort_order) VALUES
-- A領域: そうだ〜ちがう
('agreement', 4, 'そうだ', 1),
('agreement', 3, 'まあそうだ', 2),
('agreement', 2, 'ややちがう', 3),
('agreement', 1, 'ちがう', 4),

