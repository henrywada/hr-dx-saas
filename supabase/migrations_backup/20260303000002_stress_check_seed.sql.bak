('A', 13, 13, '私の部署と他の部署とはうまが合わない',
 'agreement', false, '職場の対人関係でのストレス', 'stressor', false),
('A', 14, 14, '私の職場の雰囲気は友好的である',
 'agreement', true, '職場の対人関係でのストレス', 'stressor', false),

-- 職場環境によるストレス: 素点 = 5-A15
('A', 15, 15, '私の職場の作業環境（騒音、照明、温度、換気など）はよくない',
